# ───────────────────────────────────────────────────────────────────────────
# RocketCourse environment template. Copy to `.env` for local dev (run with
# `netlify dev` so Functions + env are loaded). NEVER commit a real `.env`.
# Anything prefixed VITE_ is bundled into the browser — only PUBLIC values there.
# ───────────────────────────────────────────────────────────────────────────

# ── Supabase (client) ──────────────────────────────────────────────────────
# Public, safe to ship in the browser bundle.
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your_key_here

# ── Supabase (server only) ─────────────────────────────────────────────────
# SECRET. Used by Netlify Functions (webhook, entitlement, AI) to bypass RLS.
# Never prefix with VITE_. Set in the Netlify dashboard for production.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ── OpenAI (server only) ───────────────────────────────────────────────────
# SECRET. Server-side only (netlify/functions/openai.ts). Never prefix VITE_.
OPENAI_API_KEY=sk-your-openai-key-here
# Optional: default chat model (falls back to gpt-4o-mini).
# OPENAI_MODEL=gpt-4o-mini

# ── Stripe (client) ────────────────────────────────────────────────────────
# Publishable key is safe in the browser. Use the TEST key (pk_test_…) for the demo.
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your_key_here

# ── Stripe (server only) ───────────────────────────────────────────────────
# SECRET. Test mode for the demo (sk_test_…). Never prefix with VITE_.
STRIPE_SECRET_KEY=sk_test_your_key_here
# From the Stripe webhook endpoint config (whsec_…). Verifies webhook signatures.
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# Stripe Price IDs — created by the Stripe sync step (test mode). One per self-serve plan.
STRIPE_PRICE_INDIVIDUAL_SEMESTER=price_xxx
STRIPE_PRICE_INDIVIDUAL_ANNUAL=price_xxx
STRIPE_PRICE_MONTHLY_INSTRUCTOR=price_xxx
STRIPE_PRICE_DESIGNER_PRO=price_xxx
STRIPE_PRICE_TEAM=price_xxx

# ── App URLs ───────────────────────────────────────────────────────────────
# Used to build Checkout success/cancel + auth redirect URLs. No trailing slash.
APP_URL=http://localhost:8888
VITE_APP_URL=http://localhost:8888

# ── Transactional email (server only) ──────────────────────────────────────
# Powers BOTH the Contact page (netlify/functions/contact.ts) AND workspace invite
# emails (netlify/functions/workspace-manage.ts via _shared/email.ts).
# SECRET. Resend API key. Never prefix with VITE_.
# If UNSET, email degrades gracefully — the contact form falls back to a mailto link,
# and workspace invites fall back to a copyable invite link (no email sent, no cost).
RESEND_API_KEY=re_your_resend_api_key_here
# Destination inbox for the contact form. Defaults to rocketproofai@gmail.com when unset.
CONTACT_TO_EMAIL=rocketproofai@gmail.com
# Verified Resend sender. Defaults to "RocketCourse <onboarding@resend.dev>" when unset.
CONTACT_FROM_EMAIL=RocketCourse <onboarding@resend.dev>
# Optional: a separate verified sender for invite emails. Falls back to CONTACT_FROM_EMAIL.
# INVITE_FROM_EMAIL=RocketCourse <team@yourdomain.edu>
# Note: the contact subject is always prefixed "[RocketCourse Inquiry]" because that
# inbox is shared with Rocketproof.
